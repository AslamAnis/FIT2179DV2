{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Bar chart showing the projected annual financial saving a household could achieve by replacing mains water with captured rainwater. The estimate assumes a 200 m² roof footprint, an 85% collection efficiency (allowing for evaporation, first-flush diversion, gutter losses) and the prevailing household tariff for each year. Hovering reveals all three input quantities.",

  "title": {
    "text": "What Your Roof Could Save You",
    "subtitle": "Estimated household savings from rainwater capture ($/year) · 2014-15 to 2023-24",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },

  "width": "container",
  "height": 360,
  "autosize": { "type": "fit", "contains": "padding" },

  "data": {
    "url": "data/total_consumption_rainfall.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    {
      "lookup": "Year",
      "from": {
        "data": { "url": "data/water_prices_wide.csv", "format": { "type": "csv" } },
        "key": "Year",
        "fields": ["Household_Price"]
      }
    },
    { "calculate": "(datum.Rainfall_mm * 200 * 0.85) / 1000",            "as": "Yield_kL"        },
    { "calculate": "datum.Yield_kL * datum.Household_Price",             "as": "Annual_Savings" }
  ],

  "layer": [
    {
      "description": "Savings bars.",
      "mark": {
        "type": "bar",
        "color": "#10b981",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "sort": null,
          "axis": {
            "title": "Financial Year",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "titlePadding": 12,
            "labelFontSize": 11,
            "labelColor": "#475569",
            "labelAngle": -30,
            "grid": false,
            "domainColor": "#e2e8f0",
            "tickColor": "#e2e8f0"
          }
        },
        "y": {
          "field": "Annual_Savings",
          "type": "quantitative",
          "scale": { "zero": true, "nice": true },
          "axis": {
            "title": "Estimated saving ($/year)",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "labelFontSize": 11,
            "labelColor": "#475569",
            "format": "$,.0f",
            "gridColor": "#e2e8f0",
            "gridDash": [3, 3]
          }
        },
        "tooltip": [
          { "field": "Year",            "type": "ordinal",      "title": "Year"                                  },
          { "field": "Rainfall_mm",     "type": "quantitative", "title": "Rainfall (mm)",        "format": ",.0f" },
          { "field": "Yield_kL",        "type": "quantitative", "title": "Yield (kL)",           "format": ".2f"  },
          { "field": "Household_Price", "type": "quantitative", "title": "Mains price ($/kL)",   "format": "$.2f" },
          { "field": "Annual_Savings",  "type": "quantitative", "title": "Estimated saving",     "format": "$.2f" }
        ]
      }
    },
    {
      "description": "Value labels on top of every bar.",
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -4,
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#065f46",
        "font": "Inter, system-ui, sans-serif"
      },
      "encoding": {
        "x":    { "field": "Year",            "type": "ordinal" },
        "y":    { "field": "Annual_Savings",  "type": "quantitative" },
        "text": { "field": "Annual_Savings",  "type": "quantitative", "format": "$.0f" }
      }
    }
  ],

  "config": {
    "background": "#ffffff",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "view": { "stroke": "transparent" },
    "tooltip": { "theme": "light" }
  }
}
