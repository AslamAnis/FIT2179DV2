{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Normalized 100% stacked area chart tracking proportional water use shares across sectors from 2014-15 to 2023-24 with interactive hover selection rules.",
  "title": {
    "text": "Who Claims the Drops?",
    "subtitle": "Percentage share of total national distributed water use (GL) by sector · 2014–2024",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },
  "width": "container",
  "height": 380,
  "autosize": { "type": "fit", "contains": "padding" },
  "data": {
    "url": "data/distributed_water_use.csv",
    "format": { "type": "csv" }
  },
  "transform": [
    {
      "fold": ["Agriculture", "Households", "Manufacturing", "Mining", "Other_Industries"],
      "as": ["Sector", "Water_Use"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {"strokeWidth": 0.5, "color": "#ffffff"},
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "axis": {
            "title": "Financial Year",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "titlePadding": 12,
            "labelFontSize": 11,
            "labelColor": "#475569",
            "labelAngle": -30,
            "grid": false,
            "domainColor": "#e2e8f0",
            "tickColor": "#e2e8f0"
          }
        },
        "y": {
          "aggregate": "sum",
          "field": "Water_Use",
          "type": "quantitative",
          "stack": "normalize",
          "axis": {
            "title": "Proportional Share of Water Use (%)",
            "format": "%",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "labelFontSize": 11,
            "labelColor": "#475569",
            "gridColor": "#e2e8f0"
          }
        },
        "color": {
          "field": "Sector",
          "type": "nominal",
          "scale": {
            "domain": ["Agriculture", "Households", "Manufacturing", "Mining", "Other_Industries"],
            "range": ["#3b82f6", "#f97316", "#10b981", "#8b5cf6", "#64748b"]
          },
          "legend": {
            "title": "Sector",
            "orient": "right",
            "titleFont": "Inter, system-ui, sans-serif",
            "labelFont": "Inter, system-ui, sans-serif",
            "offset": 12
          }
        }
      }
    },
    {
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "fields": ["Year"],
            "nearest": true,
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "rule",
        "color": "#0f172a",
        "strokeWidth": 1.2,
        "strokeDash": [4, 4]
      },
      "encoding": {
        "x": {"field": "Year", "type": "ordinal"},
        "opacity": {
          "condition": { "param": "hover", "empty": false, "value": 0.8 },
          "value": 0
        },
        "tooltip": [
          { "field": "Year", "type": "ordinal", "title": "Year" },
          { "field": "Sector", "type": "nominal", "title": "Sector" },
          { "field": "Water_Use", "type": "quantitative", "title": "Volume (GL)", "format": "," }
        ]
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "view": { "stroke": "transparent" },
    "tooltip": { "theme": "light" }
  }
}
