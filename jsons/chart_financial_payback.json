{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Economic Payback Runway",
    "subtitle": "Projected annual financial utility bill savings ($) via household rainwater offsets",
    "fontSize": 16, "fontWeight": "bold", "anchor": "start", "color": "#0f172a"
  },
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/total_consumption_rainfall.csv"
  },
  "transform": [
    {
      "lookup": "Year",
      "from": {
        "data": {"url": "data/water_prices.csv"},
        "key": "Year",
        "fields": ["Sector", "Price_per_kL"]
      }
    },
    {"filter": "datum.Sector == 'Household'"},
    {
      "calculate": "((datum.Rainfall_mm * 200 * 0.85) / 1000) * datum.Price_per_kL",
      "as": "Annual_Savings"
    }
  ],
  "mark": {"type": "bar", "color": "#10b981", "cornerRadiusTopLeft": 4, "cornerRadiusTopRight": 4},
  "encoding": {
    "x": {"field": "Year", "type": "ordinal", "axis": {"title": "Financial Year"}},
    "y": {"field": "Annual_Savings", "type": "quantitative", "axis": {"title": "Estimated Dollar Savings ($/Year)", "format": "$"}},
    "tooltip": [
      {"field": "Year", "type": "nominal"},
      {"field": "Price_per_kL", "type": "quantitative", "title": "Grid Cost ($/kL)", "format": "$.2f"},
      {"field": "Annual_Savings", "type": "quantitative", "title": "Retained Savings", "format": "$.2f"}
    ]
  },
  "config": {"view": {"stroke": "transparent"}, "font": "Inter, sans-serif"}
}
