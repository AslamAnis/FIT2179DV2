{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Rainwater Yield Optimization Potential",
    "subtitle": "Calculated annual harvest capability (Litres) based on an average 200sqm residential roof footprint",
    "fontSize": 16, "fontWeight": "bold", "anchor": "start", "color": "#0f172a"
  },
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/total_consumption_rainfall.csv"
  },
  "transform": [
    {
      "calculate": "datum.Rainfall_mm * 200 * 0.85",
      "as": "Calculated_Yield_Liters"
    }
  ],
  "mark": {"type": "line", "color": "#0284c7", "strokeWidth": 3, "point": true},
  "encoding": {
    "x": {"field": "Year", "type": "ordinal", "axis": {"title": "Financial Year"}},
    "y": {"field": "Calculated_Yield_Liters", "type": "quantitative", "axis": {"title": "Potential Yield Caught (Litres/Year)"}},
    "tooltip": [
      {"field": "Year", "type": "nominal"},
      {"field": "Rainfall_mm", "type": "quantitative", "title": "Rainfall (mm)"},
      {"field": "Calculated_Yield_Liters", "type": "quantitative", "title": "Potential Harvest (L)", "format": ","}
    ]
  },
  "config": {"view": {"stroke": "transparent"}, "font": "Inter, sans-serif"}
}
