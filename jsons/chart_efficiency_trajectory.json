{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Connected scatter plot tracking the chronological trajectory of commercial water intensity against domestic consumption baselines.",
  "title": {
    "text": "The Macro Efficiency Path",
    "subtitle": "Tracking industrial water intensity (ML/$m GVA) vs. average domestic use (kL) · 2014–2024",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },
  "width": "container",
  "height": 400,
  "autosize": { "type": "fit", "contains": "padding" },
  "data": {
    "url": "data/industry_intensity.csv",
    "format": { "type": "csv" }
  },
  "layer": [
    {
      "description": "The historical trail connecting chronological points",
      "mark": {
        "type": "line",
        "color": "#cbd5e1",
        "strokeWidth": 2,
        "interpolate": "linear"
      },
      "encoding": {
        "x": {
          "field": "Household_Use_kL",
          "type": "quantitative",
          "scale": {"zero": false, "padding": 15}
        },
        "y": {
          "field": "Industry_Intensity_ML",
          "type": "quantitative",
          "scale": {"zero": false, "padding": 15}
        }
      }
    },
    {
      "description": "Interactive scatter targets containing text data labels",
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "color": "#0284c7"
      },
      "encoding": {
        "x": {
          "field": "Household_Use_kL",
          "type": "quantitative",
          "axis": {
            "title": "Average Household Water Use (kL per Household)",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "labelFontSize": 11,
            "labelColor": "#475569",
            "gridColor": "#e2e8f0"
          }
        },
        "y": {
          "field": "Industry_Intensity_ML",
          "type": "quantitative",
          "axis": {
            "title": "Industrial Water Intensity (ML per $m Gross Value Added)",
            "titleFontSize": 11,
            "titleColor": "#475569",
            "labelFontSize": 11,
            "labelColor": "#475569",
            "gridColor": "#e2e8f0"
          }
        },
        "tooltip": [
          { "field": "Year", "type": "nominal", "title": "Financial Year" },
          { "field": "Household_Use_kL", "type": "quantitative", "title": "Avg Household Use (kL)", "format": ".1f" },
          { "field": "Industry_Intensity_ML", "type": "quantitative", "title": "Industrial Intensity (ML/$m)", "format": ".2f" }
        ]
      }
    },
    {
      "description": "Year annotations placed right above the data points to clear up visual clutter",
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 10,
        "color": "#64748b",
        "font": "Inter, system-ui, sans-serif"
      },
      "encoding": {
        "x": { "field": "Household_Use_kL", "type": "quantitative" },
        "y": { "field": "Industry_Intensity_ML", "type": "quantitative" },
        "text": { "field": "Year", "type": "nominal" }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "view": { "stroke": "transparent" },
    "tooltip": { "theme": "light" }
  }
}
