{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Side-by-side line series showing the trend in average price per kilolitre for the Household and Industry sectors from 2014-15 to 2023-24. Because the two sectors operate at very different price scales (cents per kL versus dollars per kL), each series is drawn against its own y-axis. A faint dashed crosshair on hover highlights the selected year and reveals tooltips for both series simultaneously.",

  "title": {
    "text": "Households Pay Ten Times What Industry Pays",
    "subtitle": "Average national price of water by sector ($/kL) · 2014-15 to 2023-24",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },

  "width": "container",
  "height": 380,
  "autosize": { "type": "fit", "contains": "padding" },

  "data": {
    "url": "data/water_prices.csv",
    "format": { "type": "csv" }
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "sort": null,
      "axis": {
        "title": "Financial Year",
        "titleFontSize": 11,
        "titleColor": "#475569",
        "titlePadding": 12,
        "labelFontSize": 11,
        "labelColor": "#475569",
        "labelAngle": -30,
        "grid": false,
        "domainColor": "#e2e8f0",
        "tickColor": "#e2e8f0"
      }
    }
  },

  "layer": [
    {
      "description": "LAYER 1 - Household price line on the LEFT y-axis. Drawn first so it sits visually beneath the focus dots.",
      "transform": [ { "filter": "datum.Sector == 'Household'" } ],
      "mark": {
        "type": "line",
        "color": "#0284c7",
        "strokeWidth": 2.5,
        "interpolate": "monotone",
        "strokeCap": "round",
        "point": { "filled": true, "size": 55, "color": "#0284c7", "stroke": "#ffffff", "strokeWidth": 1.2 }
      },
      "encoding": {
        "y": {
          "field": "Price_per_kL",
          "type": "quantitative",
          "scale": { "zero": false, "nice": true, "padding": 8 },
          "axis": {
            "title": "Household price ($/kL)",
            "titleColor": "#0284c7",
            "titleFontSize": 11,
            "titlePadding": 10,
            "labelColor": "#0284c7",
            "labelFontSize": 11,
            "format": "$.2f",
            "gridColor": "#e2e8f0",
            "gridDash": [3, 3],
            "domainColor": "#e2e8f0",
            "tickColor": "#e2e8f0"
          }
        },
        "tooltip": [
          { "field": "Year",         "type": "ordinal",      "title": "Year"                                  },
          { "field": "Sector",       "type": "nominal",      "title": "Sector"                                },
          { "field": "Price_per_kL", "type": "quantitative", "title": "Price ($/kL)", "format": "$.2f"        }
        ]
      }
    },
    {
      "description": "LAYER 2 - Industry price line on the RIGHT y-axis. Two-decimal dollar format keeps both axes legible.",
      "transform": [ { "filter": "datum.Sector == 'Industry'" } ],
      "mark": {
        "type": "line",
        "color": "#e8651a",
        "strokeWidth": 2.5,
        "interpolate": "monotone",
        "strokeDash": [6, 4],
        "strokeCap": "round",
        "point": { "filled": true, "size": 55, "color": "#e8651a", "stroke": "#ffffff", "strokeWidth": 1.2 }
      },
      "encoding": {
        "y": {
          "field": "Price_per_kL",
          "type": "quantitative",
          "scale": { "zero": false, "nice": true, "padding": 8 },
          "axis": {
            "title": "Industry price ($/kL)",
            "orient": "right",
            "titleColor": "#c4541a",
            "titleFontSize": 11,
            "titlePadding": 10,
            "labelColor": "#c4541a",
            "labelFontSize": 11,
            "format": "$.2f",
            "grid": false,
            "domainColor": "#e2e8f0",
            "tickColor": "#e2e8f0"
          }
        },
        "tooltip": [
          { "field": "Year",         "type": "ordinal",      "title": "Year"                                  },
          { "field": "Sector",       "type": "nominal",      "title": "Sector"                                },
          { "field": "Price_per_kL", "type": "quantitative", "title": "Price ($/kL)", "format": "$.2f"        }
        ]
      }
    },
    {
      "description": "LAYER 3 - Hover crosshair. nearest:true snaps to the closest financial year.",
      "params": [
        {
          "name": "hover",
          "select": { "type": "point", "fields": ["Year"], "nearest": true, "on": "mouseover", "clear": "mouseout" }
        }
      ],
      "mark": { "type": "rule", "color": "#94a3b8", "strokeWidth": 1, "strokeDash": [4, 4] },
      "encoding": {
        "opacity": {
          "condition": { "param": "hover", "empty": false, "value": 0.75 },
          "value": 0
        }
      }
    },
    {
      "description": "LAYER 4 - Inline annotation calling out the divergence at the latest data point.",
      "data": {
        "values": [
          { "Year": "2023-24", "y": 3.71, "label": "Households: $3.71/kL", "anchor": "middle" },
          { "Year": "2018-19", "y": 3.44, "label": "10.6x the industry rate", "anchor": "middle" }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -8,
        "dy": -12,
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#64748b",
        "font": "Inter, system-ui, sans-serif"
      },
      "encoding": {
        "x":    { "field": "Year",  "type": "ordinal" },
        "y":    { "field": "y",     "type": "quantitative" },
        "text": { "field": "label", "type": "nominal" }
      }
    }
  ],

  "resolve": { "scale": { "y": "independent" } },

  "config": {
    "background": "#ffffff",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "view": { "stroke": "transparent" },
    "tooltip": { "theme": "light" }
  }
}
