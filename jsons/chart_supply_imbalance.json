{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Supply-Price Divergence Metric",
    "subtitle": "Comparing annual area-average rainfall (mm) side-by-side with household prices ($/kL)",
    "fontSize": 16, "fontWeight": "bold", "anchor": "start", "color": "#0f172a"
  },
  "width": "container",
  "height": 300,
  "data": {
    "url": "data/total_consumption_rainfall.csv"
  },
  "transform": [
    {
      "lookup": "Year",
      "from": {
        "data": {"url": "data/water_prices.csv"},
        "key": "Year",
        "fields": ["Sector", "Price_per_kL"]
      }
    },
    {"filter": "datum.Sector == 'Household'"}
  ],
  "repeat": {"layer": ["Rainfall_mm", "Price_per_kL"]},
  "spec": {
    "mark": "bar",
    "encoding": {
      "x": {"field": "Year", "type": "ordinal", "axis": {"title": "Financial Year"}},
      "y": {
        "field": {"repeat": "layer"},
        "type": "quantitative",
        "title": "Normalized Values (Rainfall vs Price)"
      },
      "color": {"datum": {"repeat": "layer"}, "type": "nominal", "scale": {"range": ["#3b82f6", "#f97316"]}}
    }
  },
  "resolve": {"scale": {"y": "independent"}},
  "config": {"view": {"stroke": "transparent"}, "font": "Inter, sans-serif"}
}
