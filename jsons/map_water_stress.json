{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Geographic choropleth map linking ABS spatial datasets to visualize domestic consumption disparities across Australian states.",
  "title": {
    "text": "The Spatial Footprint of Australian Water Demand",
    "subtitle": "Average household grid water use (kL) by state for the 2023-24 financial year",
    "fontSize": 16, "fontWeight": "bold", "anchor": "start", "color": "#0f172a", "subtitleColor": "#64748b"
  },
  "width": "container",
  "height": 400,
  "projection": {
    "type": "albers",
    "rotate": [-133, 0, 0],
    "parallels": [-18, -36]
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "url": "data/household_use_by_state.csv",
              "format": {"type": "csv"}
            },
            "key": "State",
            "fields": ["Year", "Water_Use"]
          },
          "default": "2023-24"
        },
        {"filter": "datum.Year == '2023-24'"}
      ],
      "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1},
      "encoding": {
        "color": {
          "field": "Water_Use",
          "type": "quantitative",
          "scale": {"scheme": "purples"},
          "legend": {"title": "Usage (kL/Household)", "orient": "bottom-left"}
        },
        "tooltip": [
          {"field": "properties.STATE_NAME", "type": "nominal", "title": "State"},
          {"field": "Water_Use", "type": "quantitative", "title": "Avg Consumption (kL)", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {"view": {"stroke": "transparent"}, "font": "Inter, sans-serif"}
}
