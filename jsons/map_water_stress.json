{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Geographic choropleth map linking ABS datasets to stable Monash TopoJSON boundaries to visualize domestic consumption disparities.",
  "title": {
    "text": "The Spatial Footprint of Australian Water Demand",
    "subtitle": "Average household grid water use (kL) by state for the 2023-24 financial year",
    "fontSize": 16,
    "fontWeight": "bold",
    "font": "Inter, system-ui, sans-serif",
    "anchor": "start",
    "color": "#0f172a",
    "subtitleColor": "#64748b",
    "offset": 15
  },
  "width": "container",
  "height": 400,
  "projection": {
    "type": "albers",
    "rotate": [-133, 0, 0],
    "parallels": [-18, -36]
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/DataVisualisationMonash/DataVisualisationMonash.github.io/master/assets/maps/STE_2016_AUST.json",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.STE_NAME16",
          "from": {
            "data": {
              "url": "data/household_use_by_state.csv",
              "format": {"type": "csv"}
            },
            "key": "State",
            "fields": ["Year", "Water_Use"]
          }
        },
        {"filter": "datum.Year == '2023-24'"}
      ],
      "mark": {
        "type": "geoshape", 
        "stroke": "#ffffff", 
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "Water_Use",
          "type": "quantitative",
          "scale": {
            "type": "linear",
            "scheme": "blues"
          },
          "legend": {
            "title": "Usage (kL/Household)", 
            "orient": "bottom-left",
            "offset": 10
          }
        },
        "tooltip": [
          {"field": "properties.STE_NAME16", "type": "nominal", "title": "State"},
          {"field": "Water_Use", "type": "quantitative", "title": "Avg Consumption (kL)", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Inter, system-ui, -apple-system, sans-serif"
  }
}
