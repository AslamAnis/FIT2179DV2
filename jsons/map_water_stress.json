{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Choropleth map of Australia showing average household water use (kL/year) by state for 2023-24. The boundary GeoJSON is loaded from a public Australian-states repository on GitHub, and joined to the ABS household-use CSV via the STATE_NAME property. Hovering a state shows its exact value.",

  "title": {
    "text": "Australia's Household Water Footprint",
    "subtitle": "Average household grid-water use (kL per dwelling) by State and Territory · 2023-24",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },

  "width": "container",
  "height": 460,

  "projection": {
    "type": "mercator",
    "center": [135, -28],
    "scale": 600
  },

  "layer": [
    {
      "description": "Light grey base shape - draws every state even if the lookup misses, so the country outline never disappears.",
      "data": {
        "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
        "format": { "type": "json", "property": "features" }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f1f5f9",
        "stroke": "#cbd5e1",
        "strokeWidth": 0.6
      }
    },
    {
      "description": "Choropleth layer - joins state geometry to the 2023-24 household-use CSV via STATE_NAME -> State.",
      "data": {
        "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "url": "data/household_use_by_state.csv",
              "format": { "type": "csv" }
            },
            "key": "State",
            "fields": ["Year", "Water_Use"]
          }
        },
        { "filter": "datum.Year == '2023-24'" }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#475569",
        "strokeWidth": 0.8
      },
      "encoding": {
        "color": {
          "field": "Water_Use",
          "type": "quantitative",
          "scale": {
            "type": "linear",
            "scheme": "blues",
            "domain": [140, 340]
          },
          "legend": {
            "title": "Use (kL/household)",
            "orient": "bottom-left",
            "offset": 10,
            "titleFontSize": 11,
            "labelFontSize": 11,
            "gradientLength": 180,
            "gradientThickness": 12
          }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME", "type": "nominal",      "title": "State"                          },
          { "field": "Water_Use",              "type": "quantitative", "title": "Avg use (kL)", "format": ".1f"   }
        ]
      }
    },
    {
      "description": "State acronyms drawn at hard-coded centroid coordinates. Each label is also coloured by the joined Water_Use value so it darkens against deep-blue fills and lightens on the palest states.",
      "data": {
        "values": [
          { "state": "New South Wales",              "label": "NSW", "lon": 146.5, "lat": -32.5 },
          { "state": "Victoria",                     "label": "VIC", "lon": 144.7, "lat": -37.0 },
          { "state": "Queensland",                   "label": "QLD", "lon": 144.5, "lat": -22.5 },
          { "state": "South Australia",              "label": "SA",  "lon": 135.5, "lat": -30.5 },
          { "state": "Western Australia",            "label": "WA",  "lon": 122.0, "lat": -26.0 },
          { "state": "Tasmania",                     "label": "TAS", "lon": 146.8, "lat": -42.0 },
          { "state": "Northern Territory",           "label": "NT",  "lon": 133.5, "lat": -19.5 },
          { "state": "Australian Capital Territory", "label": "ACT", "lon": 152.0, "lat": -35.5 }
        ]
      },
      "transform": [
        {
          "lookup": "state",
          "from": {
            "data": {
              "url": "data/household_use_by_state.csv",
              "format": { "type": "csv" }
            },
            "key": "State",
            "fields": ["Year", "Water_Use"]
          }
        },
        { "filter": "datum.Year == '2023-24'" }
      ],
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "encoding": {
        "longitude": { "field": "lon",     "type": "quantitative" },
        "latitude":  { "field": "lat",     "type": "quantitative" },
        "text":      { "field": "label",   "type": "nominal"      },
        "color": {
          "condition": { "test": "datum.Water_Use > 220", "value": "#ffffff" },
          "value": "#0f172a"
        }
      }
    }
  ],

  "config": {
    "background": "#ffffff",
    "view": { "stroke": "transparent" },
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "tooltip": { "theme": "light" }
  }
}
