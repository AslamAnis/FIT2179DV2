{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Small-multiples (faceted) chart showing the year-by-year trend in average household water use for each Australian state and territory. Each panel uses the same y-axis so the relative levels of usage are directly comparable. A faint orange reference line on every panel shows the national five-year average so readers can immediately see which jurisdictions sit above or below the national norm.",

  "title": {
    "text": "Every State, Side by Side",
    "subtitle": "Annual household water use (kL) by State and Territory · 2019-20 to 2023-24",
    "fontSize": 17,
    "fontWeight": "bold",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFont": "Inter, system-ui, -apple-system, sans-serif",
    "subtitleFontSize": 12,
    "subtitleFontStyle": "normal",
    "subtitleColor": "#64748b",
    "subtitlePadding": 6,
    "anchor": "start",
    "color": "#0f172a",
    "offset": 16
  },

  "data": {
    "url": "data/household_use_by_state.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    {
      "joinaggregate": [
        { "op": "mean", "field": "Water_Use", "as": "National_Mean" }
      ]
    }
  ],

  "facet": {
    "field": "State",
    "type": "nominal",
    "title": null,
    "sort": { "op": "mean", "field": "Water_Use", "order": "descending" },
    "header": {
      "labelFontSize": 11,
      "labelFontWeight": "bold",
      "labelColor": "#0f172a",
      "labelFont": "Inter, system-ui, sans-serif",
      "labelAnchor": "start",
      "labelOrient": "top",
      "labelPadding": 4
    }
  },

  "columns": 4,

  "spec": {
    "width": 200,
    "height": 130,
    "layer": [
      {
        "description": "Faint dashed reference line at the national five-year average (~187 kL).",
        "mark": { "type": "rule", "color": "#fb923c", "strokeWidth": 1, "strokeDash": [4, 3] },
        "encoding": {
          "y": { "field": "National_Mean", "type": "quantitative" }
        }
      },
      {
        "description": "State-level trend line with filled points.",
        "mark": {
          "type": "line",
          "color": "#0284c7",
          "strokeWidth": 2,
          "interpolate": "monotone",
          "point": { "filled": true, "size": 45, "color": "#0284c7", "stroke": "#ffffff", "strokeWidth": 1 }
        },
        "encoding": {
          "x": {
            "field": "Year",
            "type": "ordinal",
            "sort": null,
            "axis": {
              "title": null,
              "labelFontSize": 9,
              "labelColor": "#64748b",
              "labelAngle": -30,
              "grid": false,
              "domainColor": "#e2e8f0",
              "tickColor": "#e2e8f0"
            }
          },
          "y": {
            "field": "Water_Use",
            "type": "quantitative",
            "scale": { "zero": false, "domain": [130, 350], "nice": true },
            "axis": {
              "title": "kL per household",
              "titleFontSize": 10,
              "titleColor": "#475569",
              "labelFontSize": 9,
              "labelColor": "#475569",
              "gridColor": "#e2e8f0",
              "gridDash": [3, 3],
              "tickCount": 4
            }
          },
          "tooltip": [
            { "field": "State",     "type": "nominal",      "title": "State"                  },
            { "field": "Year",      "type": "ordinal",      "title": "Year"                   },
            { "field": "Water_Use", "type": "quantitative", "title": "Use (kL)", "format": ".1f" }
          ]
        }
      }
    ]
  },

  "config": {
    "background": "#ffffff",
    "font": "Inter, system-ui, -apple-system, sans-serif",
    "view": { "stroke": "transparent" },
    "tooltip": { "theme": "light" }
  }
}
